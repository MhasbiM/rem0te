{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/.schemas/config.schema.json",
  "productName": "rem0te-client",
  "version": "0.1.0",
  "identifier": "com.rem0te.client",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "rem0te Client",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "Remote desktop client"
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "scope": ["**"]
    }
  }
}
